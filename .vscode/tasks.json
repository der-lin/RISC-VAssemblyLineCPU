{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ModelSim: Initialize & Compile (Current Phase)",
            "type": "shell",
            "command": "cd ${fileDirname}/.. && if exist work (rd /s /q work) && vlib work && vmap work work && vlog src/*.sv",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "ModelSim: Open GUI (Current Phase)",
            "type": "shell",
            "command": "cd ${fileDirname}/.. && vsim -novopt work.testbench",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}